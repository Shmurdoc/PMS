**/bin/
**/obj/
**/TestResults/
**/logs/
**/.vs/
**/.vscode/
**/node_modules/
**/*.md
**/*.trx
tests/
.git/
.github/
.gitignore
*.sln.DotSettings
docker-compose*.yml
.env*
