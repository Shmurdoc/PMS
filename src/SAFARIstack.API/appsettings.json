{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=safaristack;Username=postgres;Password=OVERRIDE_VIA_ENV_OR_USER_SECRETS;SSL Mode=Prefer;Trust Server Certificate=true"
  },

  "SwaggerSettings": {
    "Enabled": false
  },

  "JwtSettings": {
    "SecretKey": "OVERRIDE_VIA_ENV_SAFARISTACK_JWT_SECRET_OR_USER_SECRETS",
    "Issuer": "SAFARIstack-PMS",
    "Audience": "SAFARIstack-Clients",
    "ExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },

  "RfidAuthentication": {
    "EnableApiKeyAuth": true,
    "EnableIpWhitelist": false,
    "AllowedIpAddresses": [
      "192.168.1.100",
      "192.168.1.101"
    ],
    "VelocityCheckSeconds": 5
  },

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Enrichers.Environment", "Serilog.Enrichers.Thread" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{CorrelationId}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/safaristack-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{CorrelationId}] [{MachineName}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },

  "SouthAfricanSettings": {
    "DefaultCurrency": "ZAR",
    "VATRate": 0.15,
    "TourismLevyRate": 0.01,
    "Timezone": "Africa/Johannesburg"
  },

  "EdgeBuffer": {
    "Enabled": true,
    "MaxBufferSize": 1000,
    "RetryIntervalMinutes": 5,
    "MaxRetryAttempts": 10
  },

  "AllowedOrigins": [
    "https://app.safaristack.co.za"
  ],

  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "RealIpHeader": "X-Forwarded-For",
    "ClientIdHeader": "X-ClientId",
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      {
        "Endpoint": "*:/api/auth/login",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "*:/api/auth/register",
        "Period": "1m",
        "Limit": 5
      },
      {
        "Endpoint": "*:/api/rfid/*",
        "Period": "1s",
        "Limit": 10
      }
    ]
  }
}
